# Copy this file to .env and fill in real values.

# GitHub token with Copilot access. Tip:  echo "COPILOT_GITHUB_TOKEN=$(gh auth token)" >> .env
COPILOT_GITHUB_TOKEN=ghu_replace_me

# How many self-correction iterations the orchestrator runs.
MAX_ITERATIONS=4

# Reserved (rotated by security/secrets-init.sh on each boot).
OPENCLAW_GATEWAY_TOKEN=change_me_to_a_random_secret_string
