# ── OpenClaw Agent Harness — environment ─────────────────────────────
# Copy this file to .env and fill in real values.

# GitHub Copilot token used by OpenClaw's built-in github-copilot provider.
# Must belong to an account with an active GitHub Copilot subscription
# (Individual / Business / Enterprise).
#
# Get it via:   gh auth token        (or interactive login at first run)
# Docs:         https://docs.openclaw.ai/providers/github-copilot
COPILOT_GITHUB_TOKEN=

# Fallback gateway token used only if /run/secrets/gateway-token is unreadable.
# secrets-init will rotate the real token on every boot — leave this as-is.
OPENCLAW_TOKEN=

# How many coder→tester→runner cycles before giving up.
MAX_ITERATIONS=3
