# Microsoft Foundry project endpoint (required)
FOUNDRY_PROJECT_ENDPOINT=""

# Foundry deployment names (override only if your project uses different ones)
MODEL_DEEPSEEK="DeepSeek-V4-Flash"
MODEL_GPT="gpt-5.5-1"

# Which deployment runs the orchestrator brain (defaults to gpt-5.5)
ORCHESTRATOR_MODEL="gpt-5.5-1"

# Where the durable session log is written
SESSION_DIR=./sessions

# Per-call timeout (seconds) for FoundryChatClient. NOTE: Foundry hosted runtime
# reserves the FOUNDRY_* prefix, so we use REQUEST_TIMEOUT (the old
# FOUNDRY_TIMEOUT name is still honored locally for backward compatibility).
REQUEST_TIMEOUT=180

# Optional: stable session id (otherwise a UUID is generated each launch)
# SESSION_ID=dev-001
